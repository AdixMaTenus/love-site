{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "env": {
    "KV_REST_API_URL": "",
    "KV_REST_API_TOKEN": "",
    "TELEGRAM_BOT_TOKEN": "",
    "TELEGRAM_CHAT_ID": "",
    "SITE_URL": "",
    "INITIAL_VISITS": "",
    "TELEGRAM_DEBUG": "",
    "USE_VERCEL_OG": ""
  },
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
